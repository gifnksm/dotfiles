root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[{*.bash,*.sh,*.zsh,*.nu}]
indent_style = space
indent_size = 2

[{*.toml,*.json,*.yaml,*.yml,*.kdl,*.conf,*.txt,*.el}]
indent_style = space
indent_size = 2

[*.vim]
indent_style = space
indent_size = 2

[vimrc]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 2

[{install,ci_matrix,create_archive,test_bootstrap,test_install_dry_run,test_install_normal,test_shellcheck}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
